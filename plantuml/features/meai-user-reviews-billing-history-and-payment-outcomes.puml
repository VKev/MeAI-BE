@startuml
title User Reviews Billing History And Payment Outcomes
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
hide empty members
package "Frontend" {
class "Billing History Screen" as FE1 <<Frontend>> {
  +runMainAction()
  +refreshVisibleState()
  -localState
  -validationState
}
class "Checkout Result Screen" as FE2 <<Frontend>> {
  +runMainAction()
  +refreshVisibleState()
  -localState
  -validationState
}
class "Billing Filters And Summary Cards" as FE3 <<Frontend>> {
  +runMainAction()
  +refreshVisibleState()
  -localState
  -validationState
}
}
package "Backend Services" {
class "Transaction Controller" as BE1 <<Backend>> {
  +handleRequest()
  +coordinateFlow()
  -domainRules
  -integrationPorts
}
class "Subscription Purchase Confirmation Flow" as BE2 <<Backend>> {
  +handleRequest()
  +coordinateFlow()
  -domainRules
  -integrationPorts
}
class "Billing Read Model" as BE3 <<Backend>> {
  +handleRequest()
  +coordinateFlow()
  -domainRules
  -integrationPorts
}
}
package "External Systems And Storage" {
class "Transaction Database" as INT1 <<Integration>> {
  +sendOrReceive()
  +returnResult()
  -transportConfig
  -retryRules
}
class "Stripe" as INT2 <<Integration>> {
  +sendOrReceive()
  +returnResult()
  -transportConfig
  -retryRules
}
}
FE1 --> FE2
FE2 --> FE3
FE1 --> BE1
BE1 --> BE2
BE2 --> BE3
BE1 --> INT1
BE2 --> INT2
INT1 --> INT2
@enduml

@startuml
title User Reviews Billing History And Payment Outcomes
autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
actor User
box "Frontend" #E8F0FE
participant "Visible Screen" as Screen
participant "Route Action Or Hook" as Hook
participant "Frontend Store And Query Cache" as Store
end box
box "Gateway And Backend" #FFF4E5
participant "API Gateway" as Gateway
participant "Primary Service" as PrimaryService
participant "Supporting Service" as SupportingService
participant "Persistence And Domain Rules" as DomainLayer
end box
box "Payments" #E8F5E9
participant "Stripe API" as StripeApi
end box

opt User lands on checkout result after a plan purchase
  User -> Screen : open checkout result page
  Screen -> Hook : confirm the Stripe purchase with metadata from the redirect
  Hook -> Gateway : POST /api/User/subscriptions/{subscriptionId}/purchase/confirm
  Gateway -> PrimaryService : confirm purchase result
  PrimaryService -> SupportingService : verify payment intent against Stripe
  SupportingService -> StripeApi : fetch payment intent and subscription outcome
  StripeApi --> SupportingService : verified payment status
  SupportingService -> DomainLayer : persist transaction and subscription outcome
  DomainLayer --> PrimaryService : confirmation saved
  PrimaryService --> Gateway : final checkout status
  Gateway --> Hook : success or failure payload
  Hook --> Screen : show the payment outcome and next navigation
end
group User reviews billing history
  User -> Screen : open transaction history
  Screen -> Hook : request billing transactions
  Hook -> Gateway : GET /api/User/transactions
  Gateway -> PrimaryService : load user transaction list
  PrimaryService -> DomainLayer : read transactions, statuses and related subscription names
  DomainLayer --> PrimaryService : transaction rows
  PrimaryService --> Gateway : billing history payload
  Gateway --> Hook : list response
  Hook -> Store : cache transaction rows
  Store --> Screen : render summary cards, filters, sorters and paged rows
  opt user changes filters or sort order
    Screen -> Hook : recompute filtered history locally from cached rows
    Hook -> Store : update visible slice
    Store --> Screen : redraw summaries and the current page
  end
  opt user wants a fresh read after payment changes
    Screen -> Hook : refetch transaction list
    Hook -> Gateway : GET /api/User/transactions
    Gateway -> PrimaryService : reload latest billing rows
    PrimaryService --> Gateway : refreshed history
    Gateway --> Hook : updated rows
    Hook -> Store : replace cached transactions
    Store --> Screen : show the latest payment outcomes
  end
end
@enduml
