@startuml
title Admin Manages The Subscription Catalog And Stripe Metadata
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
hide empty members
package "Frontend" {
class "Admin Subscription Screen" as FE1 <<Frontend>> {
  +runMainAction()
  +refreshVisibleState()
  -localState
  -validationState
}
class "Plan Editor Dialogs" as FE2 <<Frontend>> {
  +runMainAction()
  +refreshVisibleState()
  -localState
  -validationState
}
class "Plan Status Actions" as FE3 <<Frontend>> {
  +runMainAction()
  +refreshVisibleState()
  -localState
  -validationState
}
}
package "Backend Services" {
class "Admin Subscription Controller" as BE1 <<Backend>> {
  +handleRequest()
  +coordinateFlow()
  -domainRules
  -integrationPorts
}
class "Subscription Catalog Flow" as BE2 <<Backend>> {
  +handleRequest()
  +coordinateFlow()
  -domainRules
  -integrationPorts
}
class "Billing Metadata Guard" as BE3 <<Backend>> {
  +handleRequest()
  +coordinateFlow()
  -domainRules
  -integrationPorts
}
}
package "External Systems And Storage" {
class "Subscription Database" as INT1 <<Integration>> {
  +sendOrReceive()
  +returnResult()
  -transportConfig
  -retryRules
}
class "Stripe Metadata Store" as INT2 <<Integration>> {
  +sendOrReceive()
  +returnResult()
  -transportConfig
  -retryRules
}
}
FE1 --> FE2
FE2 --> FE3
FE1 --> BE1
BE1 --> BE2
BE2 --> BE3
BE1 --> INT1
BE2 --> INT2
INT1 --> INT2
@enduml

@startuml
title Admin Manages The Subscription Catalog And Stripe Metadata
autonumber
skinparam shadowing false
skinparam sequenceMessageAlign center
actor Admin
box "Frontend" #E8F0FE
participant "Visible Screen" as Screen
participant "Route Action Or Hook" as Hook
participant "Frontend Store And Query Cache" as Store
end box
box "Gateway And Backend" #FFF4E5
participant "API Gateway" as Gateway
participant "Primary Service" as PrimaryService
participant "Supporting Service" as SupportingService
participant "Persistence And Domain Rules" as DomainLayer
end box

Admin -> Screen : open admin subscriptions
Screen -> Hook : request the plan catalog
Hook -> Gateway : GET admin subscriptions endpoint
Gateway -> PrimaryService : list subscription plans
PrimaryService -> DomainLayer : read plans, limits, activation state and Stripe ids
DomainLayer --> PrimaryService : subscription catalog
PrimaryService --> Gateway : plans response
Gateway --> Hook : query result
Hook -> Store : cache the plan list
Store --> Screen : render plan cards, limits and action buttons
group Admin creates or edits a plan
  alt create a new plan
    Admin -> Screen : submit plan name, cost, duration, limits and Stripe metadata
    Screen -> Hook : create mutation
    Hook -> Gateway : POST admin subscription endpoint
    Gateway -> PrimaryService : create subscription plan
    PrimaryService -> SupportingService : validate billing metadata and limits
    SupportingService --> PrimaryService : creation allowed
    PrimaryService -> DomainLayer : persist new plan
    DomainLayer --> PrimaryService : plan created
    PrimaryService --> Gateway : success
    Gateway --> Hook : mutation success
    Hook -> Store : invalidate plan query
    Store --> Screen : show the new plan in the catalog
  else edit an existing plan
    Admin -> Screen : update pricing, limits or Stripe ids
    Screen -> Hook : update mutation
    Hook -> Gateway : PUT admin subscription endpoint
    Gateway -> PrimaryService : update subscription plan
    PrimaryService -> SupportingService : validate changed metadata
    SupportingService --> PrimaryService : update allowed
    PrimaryService -> DomainLayer : persist plan changes
    DomainLayer --> PrimaryService : updated plan
    PrimaryService --> Gateway : success
    Gateway --> Hook : mutation success
    Hook -> Store : invalidate plan query
    Store --> Screen : render the refreshed plan details
  end
end
group Admin changes plan availability
  alt deactivate one plan
    Admin -> Screen : confirm deactivate
    Screen -> Hook : call deactivate mutation
    Hook -> Gateway : deactivate endpoint
    Gateway -> PrimaryService : mark plan inactive
    PrimaryService -> DomainLayer : persist inactive status
    DomainLayer --> PrimaryService : plan deactivated
    PrimaryService --> Gateway : success
    Gateway --> Hook : mutation success
    Hook -> Store : invalidate plan query
    Store --> Screen : show inactive badge
  else activate one plan
    Admin -> Screen : confirm activate
    Screen -> Hook : call activate mutation
    Hook -> Gateway : activate endpoint
    Gateway -> PrimaryService : mark plan active
    PrimaryService -> DomainLayer : persist active status
    DomainLayer --> PrimaryService : plan activated
    PrimaryService --> Gateway : success
    Gateway --> Hook : mutation success
    Hook -> Store : invalidate plan query
    Store --> Screen : show active badge
  else hard delete one removable plan
    Admin -> Screen : confirm hard delete
    Screen -> Hook : call delete mutation
    Hook -> Gateway : delete endpoint
    Gateway -> PrimaryService : remove plan
    PrimaryService -> SupportingService : confirm the plan is safe to delete
    SupportingService --> PrimaryService : deletion allowed
    PrimaryService -> DomainLayer : delete plan row
    DomainLayer --> PrimaryService : plan deleted
    PrimaryService --> Gateway : success
    Gateway --> Hook : mutation success
    Hook -> Store : invalidate plan query
    Store --> Screen : remove the deleted plan from the list
  end
end
@enduml
