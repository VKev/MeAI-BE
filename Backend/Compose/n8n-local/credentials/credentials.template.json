[
  {
    "id": "meai-openrouter-credential",
    "name": "OpenRouter",
    "type": "openAiApi",
    "data": {
      "apiKey": "${OPENROUTER_API_KEY}",
      "url": "https://openrouter.ai/api/v1"
    }
  },
  {
    "id": "meai-brave-credential",
    "name": "Brave Search",
    "type": "httpHeaderAuth",
    "data": {
      "name": "X-Subscription-Token",
      "value": "${BRAVE_SEARCH_API_KEY}"
    }
  }
]
