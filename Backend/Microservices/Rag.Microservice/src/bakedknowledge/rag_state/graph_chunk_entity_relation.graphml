      <data key="d0">Next Video Recommendation</data>
      <data key="d1">concept</data>
      <data key="d2">Next Video Recommendation is a strategy used to encourage viewers to watch related content, enhancing overall session time.</data>
      <data key="d3">chunk-06ab9774b6e9aa0aeab7a13fdb038dbc</data>
      <data key="d4">knowledge:platform-algorithm-signals:youtube-for-future-expansion</data>
      <data key="d5">1778002890</data>
      <data key="d6" />
    </node>
    <node id="3-Second Rule">
      <data key="d0">3-Second Rule</data>
      <data key="d1">concept</data>
      <data key="d2">The 3-Second Rule refers to the guideline of delivering visual and emotional payoff quickly to engage viewers in short-form videos.</data>
      <data key="d3">chunk-40ddb34470f164e1f8baeb7a56a0e0b6</data>
      <data key="d4">knowledge:viral-hooks:3-second-rule</data>
      <data key="d5">1778002909</data>
      <data key="d6" />
    </node>
    <node id="Shorts">
      <data key="d0">Shorts</data>
      <data key="d1">content</data>
      <data key="d2">Shorts are a format for short videos on platforms aimed at quick viewer engagement, similar to Reels and TikTok.</data>
      <data key="d3">chunk-40ddb34470f164e1f8baeb7a56a0e0b6</data>
      <data key="d4">knowledge:viral-hooks:3-second-rule</data>
