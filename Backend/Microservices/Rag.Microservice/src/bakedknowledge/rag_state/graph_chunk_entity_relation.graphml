    </node>
    <node id="Carousel Pacing">
      <data key="d0">Carousel Pacing</data>
      <data key="d1">concept</data>
      <data key="d2">Carousel Pacing is a social media strategy focusing on engaging users through a series of slides that encourage swiping to the next.</data>
