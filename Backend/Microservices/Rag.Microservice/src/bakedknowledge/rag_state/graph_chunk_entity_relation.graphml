    <node id="Algorithm">
      <data key="d0">Algorithm</data>
      <data key="d1">concept</data>
      <data key="d2">An Algorithm is a set of rules or calculations that are used by platforms to determine how content is distributed to users based on engagement metrics.</data>
      <data key="d3">chunk-40ddb34470f164e1f8baeb7a56a0e0b6</data>
