    <node id="Inter Regular">
      <data key="d0">Inter Regular</data>
      <data key="d1">content</data>
      <data key="d2">Inter Regular is a clean, readable sans-serif body font used for general text.</data>
      <data key="d3">chunk-5de5f6aeb9e08a6d9fb7272ffbb72952</data>
      <data key="d4">knowledge:visual-design:font-pairing</data>
