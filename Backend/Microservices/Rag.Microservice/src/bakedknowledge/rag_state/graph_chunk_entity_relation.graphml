    <node id="Color Shifts">
      <data key="d0">Color Shifts</data>
      <data key="d1">concept</data>
      <data key="d2">Color Shifts refer to changes in color palettes that should be avoided to maintain brand consistency over time.</data>
      <data key="d3">chunk-4fea7d7f065b62f47a9e8d0484fe5cae</data>
      <data key="d4">knowledge:visual-design:brand-color-discipline</data>
      <data key="d5">1778003120</data>
      <data key="d6" />
