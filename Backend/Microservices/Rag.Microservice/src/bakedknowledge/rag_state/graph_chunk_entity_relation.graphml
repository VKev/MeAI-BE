    <node id="Color Palette">
      <data key="d0">Color Palette</data>
      <data key="d1">concept</data>
      <data key="d2">A Color Palette consists of a selection of colors used consistently to create visual identity and recognition for brand accounts.</data>
      <data key="d3">chunk-4fea7d7f065b62f47a9e8d0484fe5cae</data>
      <data key="d4">knowledge:visual-design:brand-color-discipline</data>
      <data key="d5">1778003120</data>
