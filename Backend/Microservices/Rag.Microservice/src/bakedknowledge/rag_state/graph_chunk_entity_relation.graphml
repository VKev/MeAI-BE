    <node id="Instagram">
      <data key="d0">Instagram</data>
      <data key="d1">organization</data>
      <data key="d2">Instagram is a social media platform where users can post photos and videos, commonly using carousel posts for engaging content.&lt;SEP&gt;Instagram is a social media platform where users are advised to limit posts to 1-2 per day in feeds and 2-4 in stories to maintain reach.&lt;SEP&gt;Instagram is a social media platform that utilizes various engagement signals to rank content in users' feeds.&lt;SEP&gt;Instagram is a social media platform where users share posts, often subjected to typical posting advice.&lt;SEP&gt;Instagram is a social media platform where standard feed posts default to a square format.&lt;SEP&gt;Instagram is a social media platform where multi-slide posts can be effectively utilized as part of the Carousel Pacing strategy.</data>
      <data key="d3">chunk-0a811792f6c6bb55ab55b2a2d8a2f84c&lt;SEP&gt;chunk-d1df8b74b30a35c1c95f01e1998097a2&lt;SEP&gt;chunk-099fa493d309316ed02f5deace628766&lt;SEP&gt;chunk-d3e75cfe6e58b04c27e92833c1cbcd28&lt;SEP&gt;chunk-517177c19500ba4749eba4fa06e11417&lt;SEP&gt;chunk-15d3c57e1c04f91cc88c3fede244761c</data>
      <data key="d4">knowledge:engagement-triggers:listicle-carousel-anatomy&lt;SEP&gt;knowledge:engagement-triggers:algorithm-friendly-cadence&lt;SEP&gt;knowledge:platform-algorithm-signals:instagram&lt;SEP&gt;knowledge:viral-hooks:pattern-interrupt&lt;SEP&gt;knowledge:visual-design:square-1-1-for-feed&lt;SEP&gt;knowledge:visual-design:carousel-pacing</data>
      <data key="d5">1778003151</data>
      <data key="d6" />
    </node>
    <node id="Facebook">
      <data key="d0">Facebook</data>
      <data key="d1">organization</data>
      <data key="d2">Facebook is a social media platform that allows users to connect and share content, including educational carousels.&lt;SEP&gt;Facebook is a social media platform with guidelines recommending 1-3 posts per day for pages, avoiding back-to-back postings.&lt;SEP&gt;Facebook is a social media platform that emphasizes meaningful interactions, engagement metrics, and specific content strategies for reaching a wider audience.&lt;SEP&gt;Facebook is a social media platform that also utilizes standard feed posts in a square format.&lt;SEP&gt;Facebook is a social media platform that supports multi-slide posts as part of the Carousel Pacing strategy.</data>
      <data key="d3">chunk-0a811792f6c6bb55ab55b2a2d8a2f84c&lt;SEP&gt;chunk-d1df8b74b30a35c1c95f01e1998097a2&lt;SEP&gt;chunk-b2f1e58b563431de779523f5c6b88ac3&lt;SEP&gt;chunk-517177c19500ba4749eba4fa06e11417&lt;SEP&gt;chunk-15d3c57e1c04f91cc88c3fede244761c</data>
      <data key="d4">knowledge:engagement-triggers:listicle-carousel-anatomy&lt;SEP&gt;knowledge:engagement-triggers:algorithm-friendly-cadence&lt;SEP&gt;knowledge:platform-algorithm-signals:facebook&lt;SEP&gt;knowledge:visual-design:square-1-1-for-feed&lt;SEP&gt;knowledge:visual-design:carousel-pacing</data>
      <data key="d5">1778003151</data>
      <data key="d6" />
    </node>
    <node id="LinkedIn">
      <data key="d0">LinkedIn</data>
      <data key="d1">organization</data>
      <data key="d2">LinkedIn is a professional networking site where users can share educational slideshow posts.&lt;SEP&gt;LinkedIn is a professional networking platform where users are suggested to post a maximum of once per day, emphasizing quality over quantity.&lt;SEP&gt;LinkedIn is a professional networking platform where Carousel Pacing can be applied to enhance engagement.</data>
      <data key="d3">chunk-0a811792f6c6bb55ab55b2a2d8a2f84c&lt;SEP&gt;chunk-d1df8b74b30a35c1c95f01e1998097a2&lt;SEP&gt;chunk-15d3c57e1c04f91cc88c3fede244761c</data>
      <data key="d4">knowledge:engagement-triggers:listicle-carousel-anatomy&lt;SEP&gt;knowledge:engagement-triggers:algorithm-friendly-cadence&lt;SEP&gt;knowledge:visual-design:carousel-pacing</data>
