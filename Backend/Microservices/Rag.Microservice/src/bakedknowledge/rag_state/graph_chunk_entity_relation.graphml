      <data key="d0">Thumbnail + Title Combination</data>
      <data key="d1">concept</data>
      <data key="d2">Thumbnail + Title Combination refers to the effective pairing of imagery and text that influences Click-Through Rate (CTR) on YouTube.</data>
      <data key="d3">chunk-06ab9774b6e9aa0aeab7a13fdb038dbc</data>
      <data key="d4">knowledge:platform-algorithm-signals:youtube-for-future-expansion</data>
      <data key="d5">1778002890</data>
