  <graph edgedefault="undirected">
    <node id="FAB Formula">
      <data key="d0">FAB Formula</data>
      <data key="d1">concept</data>
      <data key="d2">The FAB Formula is a marketing technique used to highlight product or service value by focusing on features, advantages, and benefits.</data>
      <data key="d3">chunk-376ce19608fd6f7974cce021cf830faf</data>
      <data key="d4">knowledge:content-formulas:fab-formula</data>
      <data key="d5">1778002096</data>
      <data key="d6" />
    </node>
    <node id="Features">
      <data key="d0">Features</data>
      <data key="d1">concept</data>
      <data key="d2">Features refer to the attributes or characteristics of a product or service.</data>
      <data key="d3">chunk-376ce19608fd6f7974cce021cf830faf</data>
      <data key="d4">knowledge:content-formulas:fab-formula</data>
      <data key="d5">1778002096</data>
      <data key="d6" />
    </node>
    <node id="Advantages">
      <data key="d0">Advantages</data>
      <data key="d1">concept</data>
      <data key="d2">Advantages describe why a product or service is better than its competitors.</data>
      <data key="d3">chunk-376ce19608fd6f7974cce021cf830faf</data>
      <data key="d4">knowledge:content-formulas:fab-formula</data>
      <data key="d5">1778002096</data>
      <data key="d6" />
    </node>
    <node id="Benefits">
      <data key="d0">Benefits</data>
      <data key="d1">concept</data>
      <data key="d2">Benefits represent the positive outcomes customers receive from using a product or service.</data>
      <data key="d3">chunk-376ce19608fd6f7974cce021cf830faf</data>
      <data key="d4">knowledge:content-formulas:fab-formula</data>
      <data key="d5">1778002096</data>
      <data key="d6" />
    </node>
    <node id="Product Descriptions">
      <data key="d0">Product Descriptions</data>
      <data key="d1">content</data>
      <data key="d2">Product descriptions are written texts that provide detailed information about a product's features and benefits.</data>
      <data key="d3">chunk-376ce19608fd6f7974cce021cf830faf</data>
      <data key="d4">knowledge:content-formulas:fab-formula</data>
      <data key="d5">1778002096</data>
      <data key="d6" />
    </node>
    <node id="Sales Pages">
      <data key="d0">Sales Pages</data>
      <data key="d1">content</data>
      <data key="d2">Sales pages are web pages designed to persuade visitors to purchase a product or service.&lt;SEP&gt;Sales Pages are web pages designed to persuade visitors to make a purchase, leveraging the AIDA Formula.</data>
      <data key="d3">chunk-376ce19608fd6f7974cce021cf830faf&lt;SEP&gt;chunk-b9d8b56b62ba4006d34691e3a08c8b6d</data>
      <data key="d4">knowledge:content-formulas:fab-formula&lt;SEP&gt;knowledge:content-formulas:aida-formula</data>
      <data key="d5">1778002191</data>
      <data key="d6" />
    </node>
    <node id="E-Commerce Posts">
      <data key="d0">E-Commerce Posts</data>
      <data key="d1">content</data>
      <data key="d2">E-commerce posts are online posts promoting products for sale, typically on social media or websites.</data>
      <data key="d3">chunk-376ce19608fd6f7974cce021cf830faf</data>
      <data key="d4">knowledge:content-formulas:fab-formula</data>
      <data key="d5">1778002096</data>
      <data key="d6" />
    </node>
    <node id="Product Launch Campaigns">
      <data key="d0">Product Launch Campaigns</data>
      <data key="d1">event</data>
      <data key="d2">Product launch campaigns are marketing strategies aimed at introducing a new product to the market.</data>
      <data key="d3">chunk-376ce19608fd6f7974cce021cf830faf</data>
      <data key="d4">knowledge:content-formulas:fab-formula</data>
      <data key="d5">1778002096</data>
      <data key="d6" />
    </node>
    <node id="Instagram Product Captions">
      <data key="d0">Instagram Product Captions</data>
      <data key="d1">content</data>
      <data key="d2">Instagram product captions are written descriptions that accompany product images on Instagram, highlighting features and benefits.</data>
      <data key="d3">chunk-376ce19608fd6f7974cce021cf830faf</data>
      <data key="d4">knowledge:content-formulas:fab-formula</data>
      <data key="d5">1778002097</data>
      <data key="d6" />
    </node>
    <node id="Facebook Conversion Posts">
      <data key="d0">Facebook Conversion Posts</data>
      <data key="d1">content</data>
      <data key="d2">Facebook conversion posts are social media updates designed to drive conversions, often focused on product benefits and advantages.&lt;SEP&gt;Facebook conversion posts are social media posts aimed at converting users into customers or leads.</data>
      <data key="d3">chunk-376ce19608fd6f7974cce021cf830faf&lt;SEP&gt;chunk-2bdfa7df51d81cbf70ad08ced8717ed0</data>
      <data key="d4">knowledge:content-formulas:fab-formula&lt;SEP&gt;knowledge:content-formulas:5-objections-formula</data>
      <data key="d5">1778002206</data>
      <data key="d6" />
    </node>
    <node id="FAS Formula">
      <data key="d0">FAS Formula</data>
      <data key="d1">concept</data>
      <data key="d2">The FAS Formula is a marketing strategy that converts customer pain points into purchase intent by showcasing a solution through a structured approach.</data>
      <data key="d3">chunk-23228893e740a725d6889fc2eaf5ba2b</data>
      <data key="d4">knowledge:content-formulas:fas-formula</data>
      <data key="d5">1778002114</data>
      <data key="d6" />
    </node>
    <node id="Problem">
      <data key="d0">Problem</data>
      <data key="d1">concept</data>
      <data key="d2">The Problem is the first step in the FAS Formula, focusing on identifying customer pain points.</data>
      <data key="d3">chunk-23228893e740a725d6889fc2eaf5ba2b</data>
      <data key="d4">knowledge:content-formulas:fas-formula</data>
      <data key="d5">1778002114</data>
      <data key="d6" />
    </node>
    <node id="Agitate">
      <data key="d0">Agitate</data>
      <data key="d1">concept</data>
      <data key="d2">Agitate is the second step in the FAS Formula, which involves intensifying the identified pain or problem.</data>
      <data key="d3">chunk-23228893e740a725d6889fc2eaf5ba2b</data>
      <data key="d4">knowledge:content-formulas:fas-formula</data>
      <data key="d5">1778002114</data>
      <data key="d6" />
    </node>
    <node id="Solve">
      <data key="d0">Solve</data>
      <data key="d1">concept</data>
      <data key="d2">Solve is the third step in the FAS Formula, presenting a solution to address the identified pain points.</data>
      <data key="d3">chunk-23228893e740a725d6889fc2eaf5ba2b</data>
      <data key="d4">knowledge:content-formulas:fas-formula</data>
      <data key="d5">1778002114</data>
      <data key="d6" />
    </node>
    <node id="Content Growth System">
      <data key="d0">Content Growth System</data>
      <data key="d1">method</data>
      <data key="d2">The Content Growth System is a solution proposed to increase engagement on social media by addressing low visibility issues.</data>
      <data key="d3">chunk-23228893e740a725d6889fc2eaf5ba2b</data>
      <data key="d4">knowledge:content-formulas:fas-formula</data>
      <data key="d5">1778002114</data>
      <data key="d6" />
    </node>
    <node id="Best Use Cases">
      <data key="d0">Best Use Cases</data>
      <data key="d1">concept</data>
      <data key="d2">Best Use Cases refer to various applications of the FAS Formula, including ads, TikTok hooks, Facebook sales posts, landing pages, and service marketing.&lt;SEP&gt;Best Use Cases outlines the contexts in which the 4U Formula can be effectively applied, including TikTok hooks, Reels titles, ad headlines, email subjects, and Threads openers.&lt;SEP&gt;Best Use Cases refer to the specific scenarios wherein the AIDA Formula is most effectively applied.&lt;SEP&gt;Best Use Cases refers to specific scenarios in which the Formula can be effectively applied for marketing purposes.&lt;SEP&gt;Best Use Cases refers to specific contexts where the 3S Formula can be effectively applied, including storytelling posts and case studies.</data>
      <data key="d3">chunk-23228893e740a725d6889fc2eaf5ba2b&lt;SEP&gt;chunk-2728fcb241855085169f04bf28e99dff&lt;SEP&gt;chunk-b9d8b56b62ba4006d34691e3a08c8b6d&lt;SEP&gt;chunk-c585de4e41f3180f073833748f3c0cf3&lt;SEP&gt;chunk-9874951f786ca8d1892fa17c49d46abc</data>
      <data key="d4">knowledge:content-formulas:fas-formula&lt;SEP&gt;knowledge:content-formulas:4u-formula&lt;SEP&gt;knowledge:content-formulas:aida-formula&lt;SEP&gt;knowledge:content-formulas:3-reasons-why-formula&lt;SEP&gt;knowledge:content-formulas:3s-formula</data>
      <data key="d5">1778002258</data>
      <data key="d6" />
    </node>
    <node id="Core Psychology">
      <data key="d0">Core Psychology</data>
      <data key="d1">concept</data>
      <data key="d2">Core Psychology represents the underlying principle that people act faster to remove pain than to gain pleasure.&lt;SEP&gt;Core Psychology highlights the effectiveness of specific promises compared to vague claims in engaging an audience.&lt;SEP&gt;Core Psychology refers to the principles behind how repetition, proof, and rhythm can improve the effectiveness of persuasion in writing.&lt;SEP&gt;Core psychology in this context refers to the understanding that sales occur when resistance from potential buyers is lowered.&lt;SEP&gt;Core Psychology refers to fundamental aspects of buyer behavior, emphasizing the need for confidence, value, and trust in purchasing decisions.&lt;SEP&gt;Core Psychology describes the underlying principle that humans demonstrate a greater memory retention for stories compared to straightforward claims.&lt;SEP&gt;Core Psychology refers to the underlying principle that people engage more effectively with content when they feel understood first.</data>
      <data key="d3">chunk-23228893e740a725d6889fc2eaf5ba2b&lt;SEP&gt;chunk-2728fcb241855085169f04bf28e99dff&lt;SEP&gt;chunk-9a6353c288dc09841f67aafc96c3dd75&lt;SEP&gt;chunk-2bdfa7df51d81cbf70ad08ced8717ed0&lt;SEP&gt;chunk-c585de4e41f3180f073833748f3c0cf3&lt;SEP&gt;chunk-9874951f786ca8d1892fa17c49d46abc&lt;SEP&gt;chunk-234ab256a973602e886fc1d5f5c01843</data>
      <data key="d4">knowledge:content-formulas:fas-formula&lt;SEP&gt;knowledge:content-formulas:4u-formula&lt;SEP&gt;knowledge:content-formulas:a-forest-formula&lt;SEP&gt;knowledge:content-formulas:5-objections-formula&lt;SEP&gt;knowledge:content-formulas:3-reasons-why-formula&lt;SEP&gt;knowledge:content-formulas:3s-formula&lt;SEP&gt;knowledge:content-formulas:app-formula</data>
      <data key="d5">1778002318</data>
      <data key="d6" />
    </node>
    <node id="BAB Formula">
      <data key="d0">BAB Formula</data>
      <data key="d1">concept</data>
      <data key="d2">The BAB Formula is a framework used to illustrate the transformation from a painful current state to a desired future state.</data>
      <data key="d3">chunk-1618a62f66a5bf53d57a2a56aff4da25</data>
      <data key="d4">knowledge:content-formulas:bab-formula</data>
      <data key="d5">1778002129</data>
      <data key="d6" />
    </node>
    <node id="Before">
      <data key="d0">Before</data>
      <data key="d1">concept</data>
      <data key="d2">Before refers to the current painful state in the context of the BAB Formula.</data>
      <data key="d3">chunk-1618a62f66a5bf53d57a2a56aff4da25</data>
      <data key="d4">knowledge:content-formulas:bab-formula</data>
      <data key="d5">1778002129</data>
      <data key="d6" />
    </node>
    <node id="After">
      <data key="d0">After</data>
      <data key="d1">concept</data>
      <data key="d2">After denotes the desired future state that one aims to achieve using the BAB Formula.</data>
      <data key="d3">chunk-1618a62f66a5bf53d57a2a56aff4da25</data>
      <data key="d4">knowledge:content-formulas:bab-formula</data>
      <data key="d5">1778002129</data>
      <data key="d6" />
    </node>
    <node id="Bridge">
      <data key="d0">Bridge</data>
      <data key="d1">concept</data>
      <data key="d2">Bridge represents the product or service that connects the Before and After states in the BAB Formula.</data>
      <data key="d3">chunk-1618a62f66a5bf53d57a2a56aff4da25</data>
      <data key="d4">knowledge:content-formulas:bab-formula</data>
      <data key="d5">1778002129</data>
      <data key="d6" />
    </node>
    <node id="Budget Tracking App">
      <data key="d0">Budget Tracking App</data>
      <data key="d1">product</data>
      <data key="d2">A Budget Tracking App is a tool mentioned as an example of a service that helps users manage their finances effectively.</data>
      <data key="d3">chunk-1618a62f66a5bf53d57a2a56aff4da25</data>
      <data key="d4">knowledge:content-formulas:bab-formula</data>
      <data key="d5">1778002129</data>
      <data key="d6" />
    </node>
    <node id="SaaS Case Studies">
      <data key="d0">SaaS Case Studies</data>
      <data key="d1">concept</data>
      <data key="d2">SaaS case studies refer to examples demonstrating the effectiveness of Software as a Service solutions in achieving results.</data>
      <data key="d3">chunk-1618a62f66a5bf53d57a2a56aff4da25</data>
      <data key="d4">knowledge:content-formulas:bab-formula</data>
      <data key="d5">1778002129</data>
      <data key="d6" />
    </node>
    <node id="Reels/TikTok Transformation Content">
      <data key="d0">Reels/TikTok Transformation Content</data>
      <data key="d1">concept</data>
      <data key="d2">Reels/TikTok transformation content is a type of digital media that showcases before-and-after scenarios, often used in social media marketing.</data>
      <data key="d3">chunk-1618a62f66a5bf53d57a2a56aff4da25</data>
      <data key="d4">knowledge:content-formulas:bab-formula</data>
      <data key="d5">1778002129</data>
      <data key="d6" />
    </node>
    <node id="4C Formula">
      <data key="d0">4C Formula</data>
      <data key="d1">concept</data>
      <data key="d2">The 4C Formula represents high-quality writing standards defined by clarity, conciseness, compelling nature, and credibility.</data>
      <data key="d3">chunk-a674389a050a3af7d6ef86952824ee81</data>
      <data key="d4">knowledge:content-formulas:4c-formula</data>
      <data key="d5">1778002143</data>
      <data key="d6" />
    </node>
    <node id="Clear">
      <data key="d0">Clear</data>
      <data key="d1">concept</data>
      <data key="d2">Clear refers to writing that is easy to understand and straightforward in its message.</data>
      <data key="d3">chunk-a674389a050a3af7d6ef86952824ee81</data>
      <data key="d4">knowledge:content-formulas:4c-formula</data>
      <data key="d5">1778002143</data>
      <data key="d6" />
    </node>
    <node id="Concise">
      <data key="d0">Concise</data>
      <data key="d1">concept</data>
      <data key="d2">Concise relates to writing that is short and direct, providing quick and impactful communication.</data>
      <data key="d3">chunk-a674389a050a3af7d6ef86952824ee81</data>
      <data key="d4">knowledge:content-formulas:4c-formula</data>
      <data key="d5">1778002143</data>
      <data key="d6" />
    </node>
    <node id="Compelling">
      <data key="d0">Compelling</data>
      <data key="d1">concept</data>
      <data key="d2">Compelling describes writing that is persuasive and engages the reader effectively.</data>
      <data key="d3">chunk-a674389a050a3af7d6ef86952824ee81</data>
      <data key="d4">knowledge:content-formulas:4c-formula</data>
      <data key="d5">1778002143</data>
      <data key="d6" />
    </node>
    <node id="Credible">
      <data key="d0">Credible</data>
      <data key="d1">concept</data>
      <data key="d2">Credible means writing that is trustworthy and supported by proof, enhancing its reliability.</data>
      <data key="d3">chunk-a674389a050a3af7d6ef86952824ee81</data>
      <data key="d4">knowledge:content-formulas:4c-formula</data>
      <data key="d5">1778002143</data>
      <data key="d6" />
    </node>
    <node id="Content Writing">
      <data key="d0">Content Writing</data>
      <data key="d1">method</data>
      <data key="d2">Content writing refers to the practice of creating written content for various platforms and purposes.</data>
      <data key="d3">chunk-a674389a050a3af7d6ef86952824ee81</data>
      <data key="d4">knowledge:content-formulas:4c-formula</data>
      <data key="d5">1778002143</data>
      <data key="d6" />
    </node>
    <node id="Brand Communication">
      <data key="d0">Brand Communication</data>
      <data key="d1">method</data>
      <data key="d2">Brand communication encompasses various techniques and messages a brand uses to connect with its audience.</data>
      <data key="d3">chunk-a674389a050a3af7d6ef86952824ee81</data>
      <data key="d4">knowledge:content-formulas:4c-formula</data>
      <data key="d5">1778002143</data>
      <data key="d6" />
    </node>
    <node id="Website Copy">
      <data key="d0">Website Copy</data>
      <data key="d1">method</data>
      <data key="d2">Website copy is the written text used on web pages to inform and engage visitors.</data>
      <data key="d3">chunk-a674389a050a3af7d6ef86952824ee81</data>
      <data key="d4">knowledge:content-formulas:4c-formula</data>
      <data key="d5">1778002143</data>
      <data key="d6" />
    </node>
    <node id="4U Formula">
      <data key="d0">4U Formula</data>
      <data key="d1">concept</data>
      <data key="d2">The 4U Formula is a framework for creating compelling headlines or hooks, emphasizing four key attributes: Useful, Urgent, Unique, and Ultra-specific.</data>
      <data key="d3">chunk-2728fcb241855085169f04bf28e99dff</data>
      <data key="d4">knowledge:content-formulas:4u-formula</data>
      <data key="d5">1778002158</data>
      <data key="d6" />
    </node>
    <node id="Useful">
      <data key="d0">Useful</data>
      <data key="d1">concept</data>
      <data key="d2">Useful refers to the value provided to the audience through content.</data>
      <data key="d3">chunk-2728fcb241855085169f04bf28e99dff</data>
      <data key="d4">knowledge:content-formulas:4u-formula</data>
      <data key="d5">1778002158</data>
      <data key="d6" />
    </node>
    <node id="Urgent">
      <data key="d0">Urgent</data>
      <data key="d1">concept</data>
      <data key="d2">Urgent emphasizes the time-sensitive nature of content, highlighting immediate needs.</data>
      <data key="d3">chunk-2728fcb241855085169f04bf28e99dff</data>
      <data key="d4">knowledge:content-formulas:4u-formula</data>
      <data key="d5">1778002158</data>
      <data key="d6" />
    </node>
    <node id="Unique">
      <data key="d0">Unique</data>
      <data key="d1">concept</data>
      <data key="d2">Unique stresses the importance of content differentiation from others.</data>
      <data key="d3">chunk-2728fcb241855085169f04bf28e99dff</data>
      <data key="d4">knowledge:content-formulas:4u-formula</data>
      <data key="d5">1778002158</data>
      <data key="d6" />
    </node>
    <node id="Ultra-specific">
      <data key="d0">Ultra-specific</data>
      <data key="d1">concept</data>
      <data key="d2">Ultra-specific focuses on providing detailed and concrete information in content.</data>
      <data key="d3">chunk-2728fcb241855085169f04bf28e99dff</data>
      <data key="d4">knowledge:content-formulas:4u-formula</data>
      <data key="d5">1778002158</data>
      <data key="d6" />
    </node>
    <node id="FOREST Formula">
      <data key="d0">FOREST Formula</data>
      <data key="d1">concept</data>
      <data key="d2">The FOREST Formula is a persuasive writing framework that incorporates various rhetorical devices to enhance the effectiveness of communication.</data>
      <data key="d3">chunk-9a6353c288dc09841f67aafc96c3dd75</data>
      <data key="d4">knowledge:content-formulas:a-forest-formula</data>
      <data key="d5">1778002173</data>
      <data key="d6" />
    </node>
    <node id="Alliteration">
      <data key="d0">Alliteration</data>
      <data key="d1">method</data>
      <data key="d2">Alliteration involves the repetition of sounds to create rhythm and impact in writing.</data>
      <data key="d3">chunk-9a6353c288dc09841f67aafc96c3dd75</data>
      <data key="d4">knowledge:content-formulas:a-forest-formula</data>
      <data key="d5">1778002173</data>
      <data key="d6" />
    </node>
    <node id="Facts">
      <data key="d0">Facts</data>
      <data key="d1">data</data>
      <data key="d2">Facts represent truthful information or data used to support arguments in writing.</data>
      <data key="d3">chunk-9a6353c288dc09841f67aafc96c3dd75</data>
      <data key="d4">knowledge:content-formulas:a-forest-formula</data>
      <data key="d5">1778002173</data>
      <data key="d6" />
    </node>
    <node id="Opinions">
      <data key="d0">Opinions</data>
      <data key="d1">concept</data>
      <data key="d2">Opinions encompass personal arguments or viewpoints that contribute to persuasive writing.&lt;SEP&gt;Opinions refer to personal beliefs or views that can be shared through content creation.</data>
      <data key="d3">chunk-9a6353c288dc09841f67aafc96c3dd75&lt;SEP&gt;chunk-329eaee1aec1b601d88beada37d0d6f0</data>
      <data key="d4">knowledge:content-formulas:a-forest-formula&lt;SEP&gt;knowledge:content-formulas:platform-mapping-threads-post</data>
      <data key="d5">1778002387</data>
      <data key="d6" />
    </node>
    <node id="Repetition">
      <data key="d0">Repetition</data>
      <data key="d1">method</data>
      <data key="d2">Repetition is the act of restating key ideas to enhance retention and persuasion.</data>
      <data key="d3">chunk-9a6353c288dc09841f67aafc96c3dd75</data>
      <data key="d4">knowledge:content-formulas:a-forest-formula</data>
      <data key="d5">1778002173</data>
      <data key="d6" />
    </node>
    <node id="Examples">
      <data key="d0">Examples</data>
      <data key="d1">content</data>
      <data key="d2">Examples include illustrative case studies or scenarios that bolster arguments in writing.</data>
      <data key="d3">chunk-9a6353c288dc09841f67aafc96c3dd75</data>
      <data key="d4">knowledge:content-formulas:a-forest-formula</data>
      <data key="d5">1778002173</data>
      <data key="d6" />
    </node>
    <node id="Statistics">
      <data key="d0">Statistics</data>
      <data key="d1">data</data>
      <data key="d2">Statistics refer to numerical data that can provide evidence and support for persuasive content.</data>
      <data key="d3">chunk-9a6353c288dc09841f67aafc96c3dd75</data>
      <data key="d4">knowledge:content-formulas:a-forest-formula</data>
      <data key="d5">1778002173</data>
      <data key="d6" />
    </node>
    <node id="Threes">
      <data key="d0">Threes</data>
      <data key="d1">method</data>
      <data key="d2">Threes involve using groups of three elements to create a pattern that aids memory and persuasion.</data>
      <data key="d3">chunk-9a6353c288dc09841f67aafc96c3dd75</data>
      <data key="d4">knowledge:content-formulas:a-forest-formula</data>
      <data key="d5">1778002173</data>
      <data key="d6" />
    </node>
    <node id="AIDA Formula">
      <data key="d0">AIDA Formula</data>
      <data key="d1">concept</data>
      <data key="d2">The AIDA Formula is a classic conversion funnel copywriting model used to guide consumer behavior towards purchasing decisions.</data>
      <data key="d3">chunk-b9d8b56b62ba4006d34691e3a08c8b6d</data>
      <data key="d4">knowledge:content-formulas:aida-formula</data>
      <data key="d5">1778002191</data>
      <data key="d6" />
    </node>
    <node id="Attention">
      <data key="d0">Attention</data>
      <data key="d1">concept</data>
      <data key="d2">Attention is the first stage of the AIDA Formula, focusing on getting noticed by the audience.</data>
      <data key="d3">chunk-b9d8b56b62ba4006d34691e3a08c8b6d</data>
      <data key="d4">knowledge:content-formulas:aida-formula</data>
      <data key="d5">1778002191</data>
      <data key="d6" />
    </node>
    <node id="Interest">
      <data key="d0">Interest</data>
      <data key="d1">concept</data>
      <data key="d2">Interest is the second stage of the AIDA Formula, aimed at building curiosity among potential customers.</data>
      <data key="d3">chunk-b9d8b56b62ba4006d34691e3a08c8b6d</data>
      <data key="d4">knowledge:content-formulas:aida-formula</data>
      <data key="d5">1778002191</data>
      <data key="d6" />
    </node>
    <node id="Desire">
      <data key="d0">Desire</data>
      <data key="d1">concept</data>
      <data key="d2">Desire is the third stage of the AIDA Formula, focused on creating a want or need for the product or service.</data>
      <data key="d3">chunk-b9d8b56b62ba4006d34691e3a08c8b6d</data>
      <data key="d4">knowledge:content-formulas:aida-formula</data>
      <data key="d5">1778002191</data>
      <data key="d6" />
    </node>
    <node id="Action">
      <data key="d0">Action</data>
      <data key="d1">concept</data>
      <data key="d2">Action is the final stage of the AIDA Formula, which encourages the audience to take a specific action.&lt;SEP&gt;Action is the third stage in the 4A Formula, involving the purchase or engagement with the brand.&lt;SEP&gt;Action is the fourth stage in the 5A Formula, where consumers make a purchase decision.</data>
      <data key="d3">chunk-b9d8b56b62ba4006d34691e3a08c8b6d&lt;SEP&gt;chunk-005e60a57bc3b89aeee55cded3275c49&lt;SEP&gt;chunk-e1c66da303b8c01ba57d0720d2885887</data>
      <data key="d4">knowledge:content-formulas:aida-formula&lt;SEP&gt;knowledge:content-formulas:4a-formula&lt;SEP&gt;knowledge:content-formulas:5a-formula</data>
      <data key="d5">1778002295</data>
      <data key="d6" />
    </node>
    <node id="Ads">
      <data key="d0">Ads</data>
      <data key="d1">content</data>
      <data key="d2">Ads are promotional materials that can utilize the AIDA Formula to capture customer attention and drive sales.</data>
      <data key="d3">chunk-b9d8b56b62ba4006d34691e3a08c8b6d</data>
      <data key="d4">knowledge:content-formulas:aida-formula</data>
      <data key="d5">1778002191</data>
      <data key="d6" />
    </node>
    <node id="Product Pages">
      <data key="d0">Product Pages</data>
      <data key="d1">content</data>
      <data key="d2">Product Pages showcase items for sale, utilizing the AIDA Formula to effectively market products.&lt;SEP&gt;Product pages are online platforms that provide detailed information and selling points about a specific product to encourage purchases.</data>
      <data key="d3">chunk-b9d8b56b62ba4006d34691e3a08c8b6d&lt;SEP&gt;chunk-c585de4e41f3180f073833748f3c0cf3</data>
      <data key="d4">knowledge:content-formulas:aida-formula&lt;SEP&gt;knowledge:content-formulas:3-reasons-why-formula</data>
      <data key="d5">1778002223</data>
      <data key="d6" />
    </node>
    <node id="Reels Scripts">
      <data key="d0">Reels Scripts</data>
      <data key="d1">content</data>
      <data key="d2">Reels Scripts are short video scripts where the AIDA Formula can be applied to engage viewers.</data>
      <data key="d3">chunk-b9d8b56b62ba4006d34691e3a08c8b6d</data>
      <data key="d4">knowledge:content-formulas:aida-formula</data>
      <data key="d5">1778002192</data>
      <data key="d6" />
    </node>
    <node id="CTAs">
      <data key="d0">CTAs</data>
      <data key="d1">concept</data>
      <data key="d2">CTAs (Call to Actions) are prompts within the AIDA Formula that encourage the audience to take a specific action.</data>
      <data key="d3">chunk-b9d8b56b62ba4006d34691e3a08c8b6d</data>
      <data key="d4">knowledge:content-formulas:aida-formula</data>
      <data key="d5">1778002192</data>
      <data key="d6" />
    </node>
    <node id="Objections Formula">
      <data key="d0">Objections Formula</data>
      <data key="d1">concept</data>
      <data key="d2">The Objections Formula is a method designed to remove common purchasing resistance by addressing various buyer concerns.</data>
      <data key="d3">chunk-2bdfa7df51d81cbf70ad08ced8717ed0</data>
      <data key="d4">knowledge:content-formulas:5-objections-formula</data>
      <data key="d5">1778002206</data>
      <data key="d6" />
    </node>
    <node id="Buying Resistance">
      <data key="d0">Buying Resistance</data>
      <data key="d1">concept</data>
      <data key="d2">Buying resistance refers to the reluctance or hesitance that potential customers may have towards making a purchase.</data>
      <data key="d3">chunk-2bdfa7df51d81cbf70ad08ced8717ed0</data>
      <data key="d4">knowledge:content-formulas:5-objections-formula</data>
      <data key="d5">1778002206</data>
      <data key="d6" />
    </node>
    <node id="Sales Copy">
      <data key="d0">Sales Copy</data>
      <data key="d1">content</data>
      <data key="d2">Sales copy is written content aimed at persuading potential customers to make a purchase or take a specific action.</data>
      <data key="d3">chunk-2bdfa7df51d81cbf70ad08ced8717ed0</data>
      <data key="d4">knowledge:content-formulas:5-objections-formula</data>
      <data key="d5">1778002206</data>
      <data key="d6" />
    </node>
    <node id="Objection Handling Posts">
      <data key="d0">Objection Handling Posts</data>
      <data key="d1">content</data>
      <data key="d2">Objection handling posts are content pieces created to address and counter common objections raised by potential buyers.</data>
      <data key="d3">chunk-2bdfa7df51d81cbf70ad08ced8717ed0</data>
      <data key="d4">knowledge:content-formulas:5-objections-formula</data>
      <data key="d5">1778002206</data>
      <data key="d6" />
    </node>
    <node id="FAQ Content">
      <data key="d0">FAQ Content</data>
      <data key="d1">content</data>
      <data key="d2">FAQ content includes common questions and answers aimed at informing or addressing concerns of potential customers.</data>
      <data key="d3">chunk-2bdfa7df51d81cbf70ad08ced8717ed0</data>
      <data key="d4">knowledge:content-formulas:5-objections-formula</data>
      <data key="d5">1778002206</data>
      <data key="d6" />
    </node>
    <node id="Landing Pages">
      <data key="d0">Landing Pages</data>
      <data key="d1">content</data>
      <data key="d2">Landing pages are standalone web pages created for marketing campaigns, focused on persuading visitors to take a specific action.&lt;SEP&gt;Landing Pages are designed to utilize the 4P Formula to convert visitors into leads or customers.</data>
      <data key="d3">chunk-2bdfa7df51d81cbf70ad08ced8717ed0&lt;SEP&gt;chunk-6a8090190a179e9e1b56f79157c0d204</data>
      <data key="d4">knowledge:content-formulas:5-objections-formula&lt;SEP&gt;knowledge:content-formulas:4p-formula</data>
      <data key="d5">1778002240</data>
      <data key="d6" />
    </node>
    <node id="Formula">
      <data key="d0">Formula</data>
      <data key="d1">concept</data>
      <data key="d2">The Formula refers to a structured approach that builds logic and trust through three answers addressing product value and trustworthiness.</data>
      <data key="d3">chunk-c585de4e41f3180f073833748f3c0cf3</data>
      <data key="d4">knowledge:content-formulas:3-reasons-why-formula</data>
      <data key="d5">1778002222</data>
      <data key="d6" />
    </node>
    <node id="Comparison Ads">
      <data key="d0">Comparison Ads</data>
      <data key="d1">content</data>
      <data key="d2">Comparison ads are a type of advertising that highlights the advantages of one product over others, ideal for demonstrating product superiority.</data>
      <data key="d3">chunk-c585de4e41f3180f073833748f3c0cf3</data>
      <data key="d4">knowledge:content-formulas:3-reasons-why-formula</data>
      <data key="d5">1778002222</data>
      <data key="d6" />
    </node>
    <node id="Short-Form Video">
      <data key="d0">Short-Form Video</data>
      <data key="d1">content</data>
      <data key="d2">Short-form video is a concise video format used for effective communication of ideas, suitable for marketing messages.&lt;SEP&gt;Short-form video includes brief video formats like Reels, Stories, TikTok, and Shorts that utilize the vertical orientation.</data>
      <data key="d3">chunk-c585de4e41f3180f073833748f3c0cf3&lt;SEP&gt;chunk-c676dbaddd0ab5a88338a4bf4ae4f4c9</data>
      <data key="d4">knowledge:content-formulas:3-reasons-why-formula&lt;SEP&gt;knowledge:visual-design:mobile-first-9-16</data>
      <data key="d5">1778003071</data>
      <data key="d6" />
    </node>
    <node id="Carousel Posts">
      <data key="d0">Carousel Posts</data>
      <data key="d1">content</data>
      <data key="d2">Carousel posts are a type of social media content format that allows multiple pieces of content to be viewed in a single post.&lt;SEP&gt;Carousel posts are a type of social media format that allows users to swipe through multiple images or videos in a single post.</data>
      <data key="d3">chunk-c585de4e41f3180f073833748f3c0cf3&lt;SEP&gt;chunk-912cd8a0b555494f59372c2fca0263a7</data>
      <data key="d4">knowledge:content-formulas:3-reasons-why-formula&lt;SEP&gt;knowledge:engagement-triggers:question-ending</data>
      <data key="d5">1778002471</data>
      <data key="d6" />
    </node>
    <node id="Threads Arguments">
      <data key="d0">Threads Arguments</data>
      <data key="d1">content</data>
      <data key="d2">Threads arguments refer to discussions or debates presented in a series of connected messages, often used in online forums or social media.</data>
      <data key="d3">chunk-c585de4e41f3180f073833748f3c0cf3</data>
      <data key="d4">knowledge:content-formulas:3-reasons-why-formula</data>
      <data key="d5">1778002223</data>
      <data key="d6" />
    </node>
    <node id="4P Formula">
      <data key="d0">4P Formula</data>
      <data key="d1">concept</data>
      <data key="d2">The 4P Formula is a strong sales persuasion method consisting of four components: Picture, Promise, Prove, and Push.</data>
      <data key="d3">chunk-6a8090190a179e9e1b56f79157c0d204</data>
      <data key="d4">knowledge:content-formulas:4p-formula</data>
      <data key="d5">1778002240</data>
      <data key="d6" />
    </node>
    <node id="Picture">
      <data key="d0">Picture</data>
      <data key="d1">concept</data>
      <data key="d2">Picture refers to the component of the 4P Formula that involves showing an attractive vision or result to the audience.</data>
      <data key="d3">chunk-6a8090190a179e9e1b56f79157c0d204</data>
      <data key="d4">knowledge:content-formulas:4p-formula</data>
      <data key="d5">1778002240</data>
      <data key="d6" />
    </node>
    <node id="Promise">
      <data key="d0">Promise</data>
      <data key="d1">method</data>
      <data key="d2">Promise is a part of the 4P Formula, focusing on making a clear commitment to the audience.&lt;SEP&gt;Promise is the second step in the APP Formula, wherein the content creator promises a value or solution to the audience.</data>
      <data key="d3">chunk-6a8090190a179e9e1b56f79157c0d204&lt;SEP&gt;chunk-234ab256a973602e886fc1d5f5c01843</data>
      <data key="d4">knowledge:content-formulas:4p-formula&lt;SEP&gt;knowledge:content-formulas:app-formula</data>
      <data key="d5">1778002317</data>
      <data key="d6" />
    </node>
    <node id="Prove">
      <data key="d0">Prove</data>
      <data key="d1">concept</data>
      <data key="d2">Prove is another element in the 4P Formula, which emphasizes the importance of providing evidence to support claims.</data>
      <data key="d3">chunk-6a8090190a179e9e1b56f79157c0d204</data>
      <data key="d4">knowledge:content-formulas:4p-formula</data>
      <data key="d5">1778002240</data>
      <data key="d6" />
    </node>
    <node id="Push">
      <data key="d0">Push</data>
      <data key="d1">concept</data>
      <data key="d2">Push is the final component of the 4P Formula that involves a call to action, urging the audience to take immediate steps.</data>
      <data key="d3">chunk-6a8090190a179e9e1b56f79157c0d204</data>
      <data key="d4">knowledge:content-formulas:4p-formula</data>
      <data key="d5">1778002240</data>
      <data key="d6" />
    </node>
    <node id="Facebook Ads">
      <data key="d0">Facebook Ads</data>
      <data key="d1">content</data>
      <data key="d2">Facebook Ads are a use case for the 4P Formula where persuasive tactics can be applied to influence potential customers.</data>
      <data key="d3">chunk-6a8090190a179e9e1b56f79157c0d204</data>
      <data key="d4">knowledge:content-formulas:4p-formula</data>
      <data key="d5">1778002240</data>
      <data key="d6" />
    </node>
    <node id="Sales Posts">
      <data key="d0">Sales Posts</data>
      <data key="d1">method</data>
      <data key="d2">Sales Posts are another application of the 4P Formula, aimed at selling products or services through effective messaging.&lt;SEP&gt;Sales posts are marketing communications aimed at promoting products or services to drive sales.</data>
      <data key="d3">chunk-6a8090190a179e9e1b56f79157c0d204&lt;SEP&gt;chunk-14aa9b8a6928b34255ea52ee4c3b45d2</data>
      <data key="d4">knowledge:content-formulas:4p-formula&lt;SEP&gt;knowledge:content-formulas:platform-mapping-facebook-post</data>
      <data key="d5">1778002344</data>
      <data key="d6" />
    </node>
    <node id="Product Launches">
      <data key="d0">Product Launches</data>
      <data key="d1">event</data>
      <data key="d2">Product Launches serve as an occasion where the 4P Formula can be effectively applied to promote new offerings.&lt;SEP&gt;Product Launches are events that introduce new products to the market with the intent of generating interest and sales.</data>
      <data key="d3">chunk-6a8090190a179e9e1b56f79157c0d204&lt;SEP&gt;chunk-8fde58ed6d6a1555100e83cef72d633d</data>
      <data key="d4">knowledge:content-formulas:4p-formula&lt;SEP&gt;knowledge:image-design-marketing:when-to-use-marketing-style</data>
      <data key="d5">1778002708</data>
      <data key="d6" />
    </node>
    <node id="3S Formula">
      <data key="d0">3S Formula</data>
      <data key="d1">concept</data>
      <data key="d2">The 3S Formula represents a storytelling framework focused on persuasion through narrative elements: Star, Story, and Solution.</data>
      <data key="d3">chunk-9874951f786ca8d1892fa17c49d46abc</data>
      <data key="d4">knowledge:content-formulas:3s-formula</data>
      <data key="d5">1778002258</data>
      <data key="d6" />
    </node>
    <node id="Star">
      <data key="d0">Star</data>
      <data key="d1">concept</data>
      <data key="d2">Star refers to the main character in a storytelling context, crucial for engaging the audience.</data>
      <data key="d3">chunk-9874951f786ca8d1892fa17c49d46abc</data>
      <data key="d4">knowledge:content-formulas:3s-formula</data>
      <data key="d5">1778002258</data>
      <data key="d6" />
    </node>
    <node id="Story">
      <data key="d0">Story</data>
      <data key="d1">concept</data>
      <data key="d2">Story encapsulates the journey or conflict that takes place in a narrative, pivotal for storytelling effectiveness.</data>
      <data key="d3">chunk-9874951f786ca8d1892fa17c49d46abc</data>
      <data key="d4">knowledge:content-formulas:3s-formula</data>
      <data key="d5">1778002258</data>
      <data key="d6" />
    </node>
    <node id="Solution">
      <data key="d0">Solution</data>
      <data key="d1">concept</data>
      <data key="d2">Solution denotes the resolution provided through an offer in the storytelling framework, completing the narrative arc.</data>
      <data key="d3">chunk-9874951f786ca8d1892fa17c49d46abc</data>
      <data key="d4">knowledge:content-formulas:3s-formula</data>
      <data key="d5">1778002258</data>
      <data key="d6" />
    </node>
    <node id="4A Formula">
      <data key="d0">4A Formula</data>
      <data key="d1">concept</data>
      <data key="d2">The 4A Formula is a brand action loop model consisting of awareness, attitude, action, and repeat action for enhancing customer engagement.</data>
      <data key="d3">chunk-005e60a57bc3b89aeee55cded3275c49</data>
      <data key="d4">knowledge:content-formulas:4a-formula</data>
      <data key="d5">1778002275</data>
      <data key="d6" />
    </node>
    <node id="Retention Strategy">
      <data key="d0">Retention Strategy</data>
      <data key="d1">concept</data>
      <data key="d2">Retention strategy refers to methods implemented to keep existing customers engaged and encourage repeat purchases.</data>
      <data key="d3">chunk-005e60a57bc3b89aeee55cded3275c49</data>
      <data key="d4">knowledge:content-formulas:4a-formula</data>
      <data key="d5">1778002275</data>
      <data key="d6" />
    </node>
    <node id="Brand Campaigns">
      <data key="d0">Brand Campaigns</data>
      <data key="d1">concept</data>
      <data key="d2">Brand campaigns are marketing efforts aimed at increasing brand awareness and positive customer perceptions.</data>
      <data key="d3">chunk-005e60a57bc3b89aeee55cded3275c49</data>
      <data key="d4">knowledge:content-formulas:4a-formula</data>
      <data key="d5">1778002275</data>
      <data key="d6" />
    </node>
    <node id="CRM Content">
      <data key="d0">CRM Content</data>
      <data key="d1">concept</data>
      <data key="d2">CRM content refers to materials used in customer relationship management to foster engagement and loyalty.</data>
      <data key="d3">chunk-005e60a57bc3b89aeee55cded3275c49</data>
      <data key="d4">knowledge:content-formulas:4a-formula</data>
      <data key="d5">1778002275</data>
      <data key="d6" />
    </node>
    <node id="Loyalty Marketing">
      <data key="d0">Loyalty Marketing</data>
      <data key="d1">concept</data>
      <data key="d2">Loyalty marketing focuses on strategies to reward and retain existing customers to encourage repeat business.</data>
      <data key="d3">chunk-005e60a57bc3b89aeee55cded3275c49</data>
      <data key="d4">knowledge:content-formulas:4a-formula</data>
      <data key="d5">1778002275</data>
      <data key="d6" />
    </node>
    <node id="Awareness">
      <data key="d0">Awareness</data>
      <data key="d1">concept</data>
      <data key="d2">Awareness is the first stage in the 4A Formula, which emphasizes knowing the brand.&lt;SEP&gt;Awareness is the first stage in the 5A Formula, where consumers become aware of a brand.</data>
      <data key="d3">chunk-005e60a57bc3b89aeee55cded3275c49&lt;SEP&gt;chunk-e1c66da303b8c01ba57d0720d2885887</data>
      <data key="d4">knowledge:content-formulas:4a-formula&lt;SEP&gt;knowledge:content-formulas:5a-formula</data>
      <data key="d5">1778002295</data>
      <data key="d6" />
    </node>
    <node id="Attitude">
      <data key="d0">Attitude</data>
      <data key="d1">concept</data>
      <data key="d2">Attitude is the second stage in the 4A Formula, focused on building a positive feeling towards the brand.</data>
      <data key="d3">chunk-005e60a57bc3b89aeee55cded3275c49</data>
      <data key="d4">knowledge:content-formulas:4a-formula</data>
      <data key="d5">1778002275</data>
      <data key="d6" />
    </node>
    <node id="Repeat Action">
      <data key="d0">Repeat Action</data>
      <data key="d1">concept</data>
      <data key="d2">Repeat Action is the fourth stage in the 4A Formula, which encourages customers to make repeat purchases.</data>
      <data key="d3">chunk-005e60a57bc3b89aeee55cded3275c49</data>
      <data key="d4">knowledge:content-formulas:4a-formula</data>
      <data key="d5">1778002275</data>
      <data key="d6" />
    </node>
    <node id="5A Formula">
      <data key="d0">5A Formula</data>
      <data key="d1">concept</data>
      <data key="d2">The 5A Formula is a modern customer journey model created by Philip Kotler, outlining stages in the buyer's journey.</data>
