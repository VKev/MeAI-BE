      <data key="d0">Static Feed Images</data>
      <data key="d1">content</data>
      <data key="d2">Static feed images refer to images used in social media posts, which must also be optimized for thumbnail viewing.</data>
      <data key="d3">chunk-134e69813d23dac6cb65275e5089cea5</data>
