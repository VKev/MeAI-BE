    </node>
    <node id="Drop-Off Curves">
      <data key="d0">Drop-Off Curves</data>
      <data key="d1">concept</data>
      <data key="d2">Drop-Off Curves illustrate viewer retention rates over time and are influenced by the video content, affecting recommendations.</data>
      <data key="d3">chunk-06ab9774b6e9aa0aeab7a13fdb038dbc</data>
      <data key="d4">knowledge:platform-algorithm-signals:youtube-for-future-expansion</data>
