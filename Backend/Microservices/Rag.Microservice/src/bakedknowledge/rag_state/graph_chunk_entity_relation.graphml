    <node id="Duplicate Audio/Video">
      <data key="d0">Duplicate Audio/Video</data>
      <data key="d1">concept</data>
      <data key="d2">Duplicate Audio/Video refers to audio or video content that is uploaded multiple times, which can affect ranking negatively.</data>
      <data key="d3">chunk-06ab9774b6e9aa0aeab7a13fdb038dbc</data>
      <data key="d4">knowledge:platform-algorithm-signals:youtube-for-future-expansion</data>
      <data key="d5">1778002890</data>
      <data key="d6" />
