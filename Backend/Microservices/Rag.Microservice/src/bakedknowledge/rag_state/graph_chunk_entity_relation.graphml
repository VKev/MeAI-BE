    <node id="Reused TikTok/Reels Content">
      <data key="d0">Reused TikTok/Reels Content</data>
      <data key="d1">concept</data>
      <data key="d2">Reused TikTok/Reels Content denotes content that is reformatted as Shorts without proper optimization, potentially leading to penalties.</data>
      <data key="d3">chunk-06ab9774b6e9aa0aeab7a13fdb038dbc</data>
      <data key="d4">knowledge:platform-algorithm-signals:youtube-for-future-expansion</data>
